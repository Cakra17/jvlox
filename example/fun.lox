fun add(a, b){
  print a + b;
}

print add; // "<fn add>".

fun add(a, b, c) {
  print a + b + c;
}

add(1, 2, 3);

fun sayHi(first, last) {
  print "Hi, " + first + " " + last + "!";
}

sayHi("Dear", "Reader");

fun fib(n) {
  if (n <= 1) return n;
  return fib(n - 2) + fib(n - 1);
}

for (var i = 0; i < 20; i = i + 1) {
  print fib(i);
}
